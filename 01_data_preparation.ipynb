    "import numpy as np\n",
    "\n",
    "filename = 'bodmas.npz'\n",
    "data = np.load(filename)\n",
    "X = data['X']  # all the feature vectors\n",
    "y = data['y']  # labels, 0 as benign, 1 as malicious\n",
    "\n",
    "print(X.shape, y.shape)"
   ]
